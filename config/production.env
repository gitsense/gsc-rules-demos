# Production Environment Configuration
# WARNING: This file contains sensitive production settings
# Changes require deployment approval from DevOps team

APP_NAME=myapp
APP_ENV=production
APP_PORT=8080
APP_HOST=0.0.0.0

# Database Configuration
DB_HOST=prod-db.internal.example.com
DB_PORT=5432
DB_NAME=myapp_production
DB_USER=app_user
DB_PASSWORD=${PROD_DB_PASSWORD}

# Redis Configuration
REDIS_HOST=prod-redis.internal.example.com
REDIS_PORT=6379
REDIS_PASSWORD=${PROD_REDIS_PASSWORD}

# External Services
API_GATEWAY_URL=https://api.example.com
CDN_URL=https://cdn.example.com
STORAGE_BUCKET=myapp-prod-assets

# Logging
LOG_LEVEL=warn
LOG_FORMAT=json

# Security
CORS_ORIGIN=https://www.example.com
SESSION_SECRET=${PROD_SESSION_SECRET}
JWT_SECRET=${PROD_JWT_SECRET}

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
